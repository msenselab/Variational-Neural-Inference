+def _softmax_centered(logits):
+    """Pure-JAX equivalent of TFP's SoftmaxCentered bijector."""
+    centered_logits = jnp.concatenate((logits, jnp.zeros((1,), dtype=logits.dtype)))
+    return softmax(centered_logits)
+
+
+def _multivariate_normal_prob(value, mean, covariance):
+    """Evaluate a full-covariance Gaussian density with stable Cholesky solves."""
+    dimension = mean.shape[0]
+    chol = jnp.linalg.cholesky(covariance)
+    whitened = jnp.linalg.solve(chol, value - mean)
+    log_det = 2.0 * jnp.log(jnp.diag(chol)).sum()
+    log_prob = -0.5 * (
+        dimension * jnp.log(2.0 * jnp.pi)
+        + log_det
+        + jnp.dot(whitened, whitened)
+    )
+    return jnp.exp(log_prob)
+
